{
  "name": "frontend",
  "private": true,
  "scripts": {
    "dev": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "pnpm --workspace-root lint:frontend",
    "lint:fix": "pnpm --workspace-root lint:fix:frontend",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "check": "pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/language-server": "^22.0.7",
    "@angular/language-service": "^22.0.7",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20.19.43",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "vitest": "^4.0.8"
  }
}
