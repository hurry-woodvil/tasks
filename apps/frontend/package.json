{
  "name": "frontend",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "pnpm prepare-db && playwright test",
    "e2e:ui": "playwright test --ui",
    "check": "pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "prepare-db": "cp fixtures/db.sample.json db.json",
    "api": "json-server --watch db.json --port 3000",
    "dev": "pnpm prepare-db && concurrently \"pnpm start\" \"pnpm api\""
  },
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/language-server": "^22.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/language-server": "^0.14.29",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20.19.43",
    "angular-eslint": "22.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "json-server": "1.0.0-beta.15",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
